<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-feature android:name="android.hardware.camera" android:required="true" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@drawable/img"
        android:label="@string/app_name"
        android:roundIcon="@drawable/img"
        android:supportsRtl="true"
        android:theme="@style/Theme.QRCodeAttendance">
        <activity
            android:name=".ActivityTeacherDashboard"
            android:exported="false" />
        <activity
            android:name=".ActivityAdminDashboard"
            android:exported="false" />
        <activity
            android:name=".ActivityStudentDashboard"
            android:exported="false" />
        <activity
            android:name=".ActivityRoleSelection"
            android:exported="false" />
        <activity
            android:name=".ActivityOnBoardingScreen"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity
            android:name=".MainActivity"
            android:exported="true" />
        <activity
            android:name=".ActivityAdminSignUp"
            android:windowSoftInputMode="adjustResize" />
        <activity
            android:name=".ActivityAdminSignIn"
            android:windowSoftInputMode="adjustResize" />
        <activity
            android:name=".ActivityTeacherSignUp"
            android:windowSoftInputMode="adjustResize" />
        <activity
            android:name=".ActivityTeacherSignIn"
            android:windowSoftInputMode="adjustResize" />
        <activity
            android:name=".ActivityStudentSignUp"
            android:windowSoftInputMode="adjustResize" />
        <activity
            android:name=".ActivityStudentSignIn"
            android:windowSoftInputMode="adjustResize" />
    </application>

</manifest>