<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark">

    <!-- Grid overlay -->

    <!-- Grid overlay — id add kiya, background hata diya -->
    <View
        android:id="@+id/gridOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:alpha="0.4"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

    <!-- Orb top-left -->
    <View
        android:id="@+id/orbTopLeft"
        android:layout_width="320dp"
        android:layout_height="320dp"
        android:background="@drawable/bg_ord_blue"
        android:alpha="0.25"
        android:layout_marginStart="-100dp"
        android:layout_marginTop="-100dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

    <!-- Orb bottom-right -->
    <View
        android:id="@+id/orbBottomRight"
        android:layout_width="240dp"
        android:layout_height="240dp"
        android:background="@drawable/bg_orb_teal"
        android:alpha="0.18"
        android:layout_marginEnd="-60dp"
        android:layout_marginBottom="-60dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Scrollable content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:scrollbars="none"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp"
            android:paddingTop="56dp">

            <!-- Badge -->
            <LinearLayout
                android:id="@+id/badgeLayout"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/bg_badge"
                android:padding="6dp"
                android:paddingStart="12dp"
                android:paddingEnd="14dp"
                android:gravity="center_vertical"
                android:layout_marginBottom="20dp">

                <View
                    android:id="@+id/pulseDot"
                    android:layout_width="7dp"
                    android:layout_height="7dp"
                    android:background="@drawable/dot_active_blue"
                    android:layout_marginEnd="7dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ATTENDANCE SYSTEM"
                    android:textSize="10sp"
                    android:textColor="@color/accent_blue"
                    android:letterSpacing="0.1"
                    android:textStyle="bold"/>
            </LinearLayout>

            <!-- Heading -->
            <TextView
                android:id="@+id/tvHeading"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Who are\nyou today?"
                android:textSize="32sp"
                android:textColor="@color/text_primary"
                android:textStyle="bold"
                android:lineSpacingMultiplier="1.1"
                android:layout_marginBottom="8dp"/>

            <!-- Subtext -->
            <TextView
                android:id="@+id/tvSubtext"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Select your role to access your\npersonalized dashboard"
                android:textSize="14sp"
                android:textColor="@color/text_muted"
                android:lineSpacingMultiplier="1.5"
                android:layout_marginBottom="36dp"/>

            <!-- Admin Card -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardAdmin"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                android:foreground="?attr/selectableItemBackground"
                app:cardBackgroundColor="@color/card_admin_bg"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="20dp"
                    android:gravity="center_vertical">

                    <!-- Icon -->
                    <androidx.cardview.widget.CardView
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        app:cardBackgroundColor="@color/icon_admin_bg"
                        app:cardCornerRadius="14dp"
                        app:cardElevation="0dp"
                        android:layout_marginEnd="16dp">
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:text="🛡️"
                            android:textSize="22sp"
                            android:gravity="center"/>
                    </androidx.cardview.widget.CardView>

                    <!-- Text -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Admin"
                            android:textSize="17sp"
                            android:textColor="@color/text_primary"
                            android:textStyle="bold"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Manage departments, users &amp; settings"
                            android:textSize="12sp"
                            android:textColor="@color/text_muted"
                            android:layout_marginTop="2dp"
                            android:layout_marginBottom="6dp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="FULL ACCESS"
                            android:textSize="9sp"
                            android:textColor="@color/accent_blue"
                            android:textStyle="bold"
                            android:letterSpacing="0.08"
                            android:background="@drawable/bg_tag_blue"
                            android:paddingStart="8dp"
                            android:paddingEnd="8dp"
                            android:paddingTop="3dp"
                            android:paddingBottom="3dp"/>
                    </LinearLayout>

                    <!-- Arrow -->
                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@drawable/ic_arrow_right"
                        android:alpha="0.4"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Teacher Card -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardTeacher"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                android:foreground="?attr/selectableItemBackground"
                app:cardBackgroundColor="@color/card_teacher_bg"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="20dp"
                    android:gravity="center_vertical">

                    <androidx.cardview.widget.CardView
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        app:cardBackgroundColor="@color/icon_teacher_bg"
                        app:cardCornerRadius="14dp"
                        app:cardElevation="0dp"
                        android:layout_marginEnd="16dp">
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:text="📋"
                            android:textSize="22sp"
                            android:gravity="center"/>
                    </androidx.cardview.widget.CardView>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Teacher"
                            android:textSize="17sp"
                            android:textColor="@color/text_primary"
                            android:textStyle="bold"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Generate QR codes &amp; track attendance"
                            android:textSize="12sp"
                            android:textColor="@color/text_muted"
                            android:layout_marginTop="2dp"
                            android:layout_marginBottom="6dp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="EDUCATOR"
                            android:textSize="9sp"
                            android:textColor="@color/accent_teal"
                            android:textStyle="bold"
                            android:letterSpacing="0.08"
                            android:background="@drawable/bg_tag_teal"
                            android:paddingStart="8dp"
                            android:paddingEnd="8dp"
                            android:paddingTop="3dp"
                            android:paddingBottom="3dp"/>
                    </LinearLayout>

                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@drawable/ic_arrow_right"
                        android:alpha="0.4"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Student Card -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardStudent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="32dp"
                android:foreground="?attr/selectableItemBackground"
                app:cardBackgroundColor="@color/card_student_bg"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="20dp"
                    android:gravity="center_vertical">

                    <androidx.cardview.widget.CardView
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        app:cardBackgroundColor="@color/icon_student_bg"
                        app:cardCornerRadius="14dp"
                        app:cardElevation="0dp"
                        android:layout_marginEnd="16dp">
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:text="🎓"
                            android:textSize="22sp"
                            android:gravity="center"/>
                    </androidx.cardview.widget.CardView>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Student"
                            android:textSize="17sp"
                            android:textColor="@color/text_primary"
                            android:textStyle="bold"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Scan QR &amp; view your attendance records"
                            android:textSize="12sp"
                            android:textColor="@color/text_muted"
                            android:layout_marginTop="2dp"
                            android:layout_marginBottom="6dp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="LEARNER"
                            android:textSize="9sp"
                            android:textColor="@color/accent_purple"
                            android:textStyle="bold"
                            android:letterSpacing="0.08"
                            android:background="@drawable/bg_tag_purple"
                            android:paddingStart="8dp"
                            android:paddingEnd="8dp"
                            android:paddingTop="3dp"
                            android:paddingBottom="3dp"/>
                    </LinearLayout>

                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@drawable/ic_arrow_right"
                        android:alpha="0.4"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Footer -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:text="University Attendance System · v2.0"
                android:textSize="11sp"
                android:textColor="#374151"/>

        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>