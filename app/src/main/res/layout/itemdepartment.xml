<?xml version="1.0" encoding="utf-8"?>
<!--
    item_department.xml
    Single row in the Department Management list: name + Edit/Delete icons.
    Matches the dark glassmorphism theme (bg_glass_card, colorPrimary).
-->
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="6dp"
    app:cardBackgroundColor="@android:color/transparent"
    app:cardCornerRadius="18dp"
    app:cardElevation="0dp"
    app:strokeWidth="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_glass_card"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="14dp">

        <FrameLayout
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:background="@drawable/bg_icon_chip">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_department"
                app:tint="@color/colorPrimary" />

        </FrameLayout>

        <TextView
            android:id="@+id/tvDepartmentName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="14dp"
            android:text="Computer Science"
            android:textColor="@color/textPrimary"
            android:textSize="15sp"
            android:textStyle="bold" />

        <ImageView
            android:id="@+id/btnEdit"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:padding="8dp"
            android:background="@drawable/bg_icon_circle_glass"
            android:src="@drawable/ic_edit"
            app:tint="@color/colorPrimary" />

        <ImageView
            android:id="@+id/btnDelete"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:layout_marginStart="10dp"
            android:padding="8dp"
            android:background="@drawable/bg_icon_circle_glass"
            android:src="@drawable/ic_delete"
            app:tint="@color/dangerRed" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>