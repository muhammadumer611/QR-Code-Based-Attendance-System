<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Base dark gradient -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="270"
                android:startColor="#0F1C2E"
                android:centerColor="#0C1420"
                android:endColor="#0A0E14"/>
            <corners
                android:bottomLeftRadius="32dp"
                android:bottomRightRadius="32dp"/>
        </shape>
    </item>

    <!-- Cyan glow accent, top right -->
    <item android:gravity="top|end" android:width="260dp" android:height="260dp">
        <shape android:shape="oval">
            <gradient
                android:type="radial"
                android:gradientRadius="260dp"
                android:centerColor="#2600E5FF"
                android:endColor="#0000E5FF"/>
        </shape>
    </item>

    <!-- subtle bottom cyan hairline -->
    <item android:gravity="bottom" android:height="1dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/glassStrokeCyan"/>
        </shape>
    </item>

</layer-list>