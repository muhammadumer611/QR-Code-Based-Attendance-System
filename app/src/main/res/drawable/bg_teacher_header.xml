<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Base dark gradient -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="270"
                android:startColor="#0A0F14"
                android:centerColor="#0D1B1F"
                android:endColor="#0A0F14"/>
            <corners
                android:bottomLeftRadius="32dp"
                android:bottomRightRadius="32dp"/>
        </shape>
    </item>

    <!-- Subtle cyan glow overlay top-right -->
    <item android:gravity="top|end" android:width="220dp" android:height="220dp">
        <shape android:shape="oval">
            <gradient
                android:type="radial"
                android:gradientRadius="220dp"
                android:startColor="#3300E5FF"
                android:endColor="#0000E5FF"/>
        </shape>
    </item>

    <!-- Bottom border glow line -->
    <item android:gravity="bottom" android:height="1dp">
        <shape android:shape="rectangle">
            <solid android:color="#4D00E5FF"/>
        </shape>
    </item>

</layer-list>